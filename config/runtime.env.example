# 统一运行时配置样例
# 所有注释都使用中文，实际部署时建议通过 Kubernetes Secret、ConfigMap 或宿主机环境变量注入。

# 认证模式
# auto: 优先复用已登录环境，缺失时回退到显式配置
# login: 只使用已登录环境
# config: 只使用显式配置
AUTH_MODE=auto

# 巡检目标
# 可选值: linux / k8s / composite
INSPECTION_TARGET=linux

# 巡检模式
# quick: 高频轻量巡检
# deep: 低频深度巡检
INSPECT_MODE=quick

# 输出目录
INSPECT_OUTPUT_DIR=/workspace/output

# 运行目录保留数量
INSPECT_RETENTION_RUNS=20

# 是否生成 docx 报告
INSPECT_DOCX=true

# Codex / 兼容 OpenAI 模型配置
CODEX_MODEL=gpt-5.4
CODEX_BASE_URL=https://your-openai-compatible-endpoint.example.com

# OpenAI 兼容鉴权
# 建议优先使用 OPENAI_API_KEY 环境变量或 Secret 挂载文件
# OPENAI_API_KEY=
# MODEL_OPENAI_API_KEY_FILE=/run/secrets/openai_api_key

# Kubernetes 凭据
# KUBECONFIG=
# K8S_KUBECONFIG_FILE=/run/secrets/kubeconfig
# K8S_CONTEXT=

# SSH 凭据
# SSH_AUTH_SOCK=
# SSH_PRIVATE_KEY_FILE=/run/secrets/ssh_private_key
# SSH_KNOWN_HOSTS_FILE=/run/secrets/known_hosts
